# SearchLab environment variables
# Copy this file to .env and fill in values as phases add secrets.
# Phase 0 requires nothing here — OpenSearch runs unauthenticated locally.

# Phase 1+ — required for the `rag` command
# OPENAI_API_KEY=                     OpenAI API key for LLM generation
# SEARCHLAB_LLM_MODEL=gpt-4o-mini     Model to use (default: gpt-4o-mini)

# searchlab-eval — service URL (optional — defaults to http://localhost:8080)
# SEARCHLAB_URL=http://localhost:8080

# OpenSearch connection (optional — defaults to localhost:9200)
# OPENSEARCH_HOST=localhost
# OPENSEARCH_PORT=9200
